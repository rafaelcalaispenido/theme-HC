                <a data-lang="privacy_policies" href="https://enotas.com.br/visao-geral-das-politicas-de-privacidade/" target="_blank">Políticas de privacidade</a>
                <i></i>
                <a data-lang="terms" href="https://enotas.com.br/termos-de-uso/" target="_blank">Termos de Uso</a>
            </div>
        </div>
    </div>
    {{#if settings.import_custom_font }}
        <link
            href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;700&family=Red+Hat+Display:wght@300;400;500;700&display=swap" rel="stylesheet">
    {{/if}}
</footer>

<script>
    const langPlaceholder = {
        /* header */
        how_can_we_help: {
            pt: 'Como podemos te ajudar?',
            en: 'How can we help you?'
        },
        hero_banner: {
            pt: 'Sou cliente e quero alterar os dados da minha conta no eNotas',
            en: 'I am a customer and want to change my account details on eNotas'
        },
        hero_banner_button: {
            pt: 'Alterar dados',
            en: 'Update details'
        },
        /* categories */
        categories_title: {
            pt: 'Encontre facilmente suas respostas explorando as categorias',
            en: 'Easily find your answers by exploring the categories'
        },
        /* blocks */
        change_password: {
            pt: 'Alterar senha',
            en: 'Change password'
        },
        company: {
            pt: 'Empresa',
            en: 'Company'
        },
        manage: {
            pt: 'Gerenciar',
            en: 'Manage'
        },
        /* footer */
        
        privacy_policies: {
            pt: 'Políticas de privacidade',
            en: 'Privacy policies'
        },
        terms: {
            pt: 'Termos de uso',
            en: 'Terms'
        },
        help_center: {
            pt: 'Central de ajuda',
            en: 'Help Center'
        },
        copyright: {
            pt: 'eNotas 2026 © - Todos os direitos reservados',
            en: 'eNotas 2026 © - All rights reserved'
        }
    };

    const getLang = () => (window.location.pathname.includes('/hc/en') ? 'en' : 'pt');

    const updateTranslations = () => {
        document.querySelectorAll('[data-lang]').forEach(el => {
            const translation = langPlaceholder[el.getAttribute('data-lang')]?.[getLang()] || el.textContent;
            el.innerHTML = translation;
        });
    };

    updateTranslations();

    new MutationObserver(() => {
        if (window.location.href !== this.lastUrl) {
            this.lastUrl = window.location.href;
            updateTranslations();
        }
    }).observe(document.body, { childList: true, subtree: true });
</script>

