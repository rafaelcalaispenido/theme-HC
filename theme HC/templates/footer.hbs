    <script>
        /* Loading */
        localStorage.setItem('ZD-launcherLabelRemoved', 'true');
        setSessionStorage('ZD-widgetOpen', false);
        widgetPresentation();
        let chatOpened = false;

        /* Scroll Events */
        document.addEventListener("DOMContentLoaded", () => {
            if (window.scrollY > topDistance) appearSupport();
        });

        let previousPosition = window.scrollY;
        const topDistance = 40;

        window.onscroll = () => {
            const currentPosition = window.scrollY;
            if (previousPosition > currentPosition && isMobile()) {
                if (currentPosition < topDistance) appearSupport(currentPosition);
            } else if (previousPosition > topDistance && isMobile()) {
                hideSupport();
            }
            previousPosition = currentPosition;
        };

        /* Widget event */
        document.querySelector('#support-channels .chat')?.addEventListener('click', () => {
            chatOpened ? closeChat() : openChat();
        });

        document.querySelector('#support-channels .whatsapp')?.addEventListener('click', () => {
            window.open('https://api.whatsapp.com/send?phone=553197052109', '_blank');
        });

        document.querySelector('#support-channels .widget-baloon')?.addEventListener('click', () => {
            chatOpened ? closeChat() : openChat();
        });

        document.querySelector('#support-channels .expand')?.addEventListener('click', () => {
            appearSupport();
        });

        /* Actions */
        function appearSupport() {
            document.querySelector('#support-channels')?.classList.remove('minimize');
        }

        function hideSupport() {
            document.querySelector('#support-channels')?.classList.add('minimize');
        }

        function openChat() {
            const supportChannels = document.querySelector('#support-channels');
            if (typeof zE !== 'undefined' || chatUserLoggedIn == false) {
                if (isMobile()) {
                    supportChannels?.classList.remove('minimize');
                } else {
                    chatOpened = true;
                    supportChannels?.classList.add('active-chat');
                }
                if(chatUserLoggedIn)
                {
                    zE('messenger', 'open');
                } else {
                    document.getElementById('widget-help').style.display = 'flex';
                    requestAnimationFrame(() => {
                        document.getElementById('widget-help').setAttribute('chat-trigger', 'opened');
                    });
                }
            }
        }

        function widgetPresentation() {
            setTimeout(() => {
                document.querySelector('#support-channels')?.classList.remove('widget-presentation');
            }, 3000);
        }

        function closeChat() {
            if (typeof zE !== 'undefined' || chatUserLoggedIn == false) {
                document.querySelector('#support-channels')?.classList.remove('active-chat');
                if(chatUserLoggedIn)
                {
                    zE('messenger', 'close');
                } else {
                    document.getElementById('widget-help').setAttribute('chat-trigger', 'closed');
                    requestAnimationFrame(() => {
                        document.getElementById('widget-help').style.display = 'none';
                    });
                }
                chatOpened = false;
            }
        }

        function isMobile() {
            return window.innerWidth <= 768;
        }

        /* User session storage */
        function setSessionStorage(key, value) {
            sessionStorage.setItem(key, JSON.stringify(value));
        }

        function getSessionStorage(key) {
            const value = sessionStorage.getItem(key);
            return value ? JSON.parse(value) : null;
        }
    
        /* widget help */
        function widgetSearchHC() {
            const input = document.getElementById('widget-search-input').value;
            const encodedQuery = encodeURIComponent(input);
            const url = `/hc/search?utf8=✓&query=${encodedQuery}`;
            window.location.href = url;
        }

        function handleKeyDown(event) {
            if (event.key === 'Enter') {
                event.preventDefault();
                widgetSearchHC();
            }
        }

    </script>

{{/if}}

